PROJECT_NAME=Atlas-Core
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=480

POSTGRES_USER=atlas
POSTGRES_PASSWORD=change-me
POSTGRES_DB=atlas_core
DATABASE_URL=postgresql://atlas:change-me@db:5432/atlas_core

REDIS_URL=redis://redis:6379/0

MINIO_ROOT_USER=atlas-minio
MINIO_ROOT_PASSWORD=change-me
MINIO_URL=http://minio:9000
MINIO_PUBLIC_URL=https://your-domain.com/minio
MINIO_ACCESS_KEY=atlas-minio
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=atlas-assets
MINIO_REGION=us-east-1

ALLOWED_EMAILS=admin@healz.com.br,operator@healz.com.br,reviewer@healz.com.br
ALLOWED_EMAIL_DOMAIN=healz.com.br
BACKEND_CORS_ORIGINS=https://your-domain.com

OPENAI_API_KEY=sk-...
# Modelo das etapas baratas (reviewer de compliance).
OPENAI_MODEL=gpt-4.1-mini
# Modelo da etapa de pesquisa. Vazio = usa OPENAI_MODEL (mini), que NAO da conta
# de multi-busca web + 14 secoes e por isso devolve secoes vazias. Use um modelo
# mais capaz aqui (ex.: gpt-4.1) para a pesquisa de concorrentes/Meta/organico.
OPENAI_RESEARCH_MODEL=gpt-4.1
OPENAI_ENABLE_WEB_SEARCH=true
OPENAI_WEB_SEARCH_CONTEXT_SIZE=high
OPENAI_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=3
# Teto de tokens de saida da pesquisa. Baixo demais = documento trunca no meio
# (secoes finais nunca sao geradas). 16000 cobre as 14 secoes com folga.
OPENAI_MAX_OUTPUT_TOKENS=16000
# ATENCAO: enquanto for "false", o runner ABORTA o pipeline antes de chamar a IA
# (runner.py:_validate_configuration). Confirme a politica de Zero Data Retention
# da sua conta OpenAI e defina "true" para liberar o onboarding com IA.
OPENAI_ZERO_DATA_RETENTION_CONFIRMED=true

# --- Dados de mercado do onboarding (fontes externas reais; todas opcionais) ---
# Vazio = a fonte e ignorada e a pesquisa segue so com web_search.
# Meta Ad Library. ATENCAO: a API so retorna anuncios COMERCIAIS na UE. No Brasil
# ela so devolve anuncios politicos/sociais -> para clinicas BR vem VAZIA. Anuncios
# comerciais BR so via navegacao manual no site da Ad Library. Deixe vazio no BR.
META_AD_LIBRARY_TOKEN=
META_AD_LIBRARY_COUNTRY=BR
# DataForSEO (volume + CPC reais; pago). Login e senha da API.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_LOCATION_CODE=2076
DATAFORSEO_LANGUAGE_CODE=pt
# Google Ads Keyword Planner (volume + CPC; gratuito, setup mais trabalhoso).
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

VITE_API_BASE_URL=/api/v1

# Segurança: chave separada para criptografia de campos (tokens OAuth).
# Se vazio, usa SECRET_KEY como fallback (retrocompatível).
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Cookie de sessão deve usar Secure=True em produção (HTTPS).
COOKIE_SECURE=true

# Token de acesso da Meta (System User do Business Manager, ads_read).
# Tokens de usuário expiram em ~60 dias; System User tokens são long-lived.
META_ACCESS_TOKEN=

# Service Account do GA4 em base64. Gerar com:
# base64 -w0 crm-integrations-XXXXX.json
GA4_SERVICE_ACCOUNT_B64=

# Redis com senha (recomendado em produção).
# REDIS_URL=redis://:senha@redis:6379/0
