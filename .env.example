# Atlas Core — Env Variables
# Copy this file to .env and fill in the values

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# JWT Secret (generate a random string for production)
JWT_SECRET=atlas-core-dev-secret-change-in-production

# Database (only change if running PostgreSQL outside Docker)
DATABASE_URL=postgresql+asyncpg://atlas:atlas_dev@localhost:5432/atlas_core
